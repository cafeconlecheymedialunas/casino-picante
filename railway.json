{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS_PHP",
    "php": {
      "version": "8.2"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT"
  }
}